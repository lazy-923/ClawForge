APP_NAME=ClawForge
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002
API_PREFIX=/api
PROJECT_ROOT=.

# LLM runtime
LLM_PROVIDER=bailian-openai-compatible
LLM_API_KEY=your-bailian-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.2

# Optional compatibility aliases
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
