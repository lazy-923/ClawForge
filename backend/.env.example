APP_NAME=ClawForge
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002
API_PREFIX=/api
PROJECT_ROOT=.

# LLM runtime
LLM_PROVIDER=bailian-openai-compatible
LLM_API_KEY=your-bailian-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.2
SESSION_COMPACTION_MODEL=qwen-plus
DREAMING_ENABLED=true
DREAMING_MIN_CONFIDENCE=0.55
DREAMING_MAX_CANDIDATES=3
DREAMING_MODEL=qwen-plus

# Optional compatibility aliases
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Embedding / RAG
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=256
RAG_CHUNK_OVERLAP=32
RAG_VECTOR_TOP_K=6
RAG_BM25_TOP_K=6
