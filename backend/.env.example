APP_NAME=ClawForge
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002
API_PREFIX=/api
PROJECT_ROOT=.

# LLM runtime
# ClawForge uses OpenAI-compatible Chat API semantics through langchain_openai.ChatOpenAI.
# Fill these with any provider that exposes /chat/completions compatible behavior.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TEMPERATURE=0.2
SESSION_COMPACTION_MODEL=
DREAMING_ENABLED=true
DREAMING_MIN_CONFIDENCE=0.55
DREAMING_MAX_CANDIDATES=3
DREAMING_MODEL=

# Embedding / RAG
# Optional. If these are empty, retrieval uses BM25 only.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
RAG_CHUNK_SIZE=256
RAG_CHUNK_OVERLAP=32
RAG_VECTOR_TOP_K=6
RAG_BM25_TOP_K=6
